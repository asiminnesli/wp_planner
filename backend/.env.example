# Database (SQLite — Render'da persistent disk kullanılır)
DATABASE_URL=file:./data/prod.db

# JWT (Render'da otomatik üretilir)
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRES_IN=7d

# Google Gemini (kullanıcılar kendi key'lerini girer)
GEMINI_API_KEY=

# Server
PORT=10000
NODE_ENV=production

# Frontend URL (Render'da kendi domain'iniz)
FRONTEND_URL=https://your-app.onrender.com
